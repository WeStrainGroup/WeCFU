# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
*.so

# pip / setuptools build outputs — re-built on demand, shipped via
# GitHub Releases (not committed to main).
dist/

# Test / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenvs
.venv/
venv/
.env

# IDE
.vscode/
.idea/

# macOS
.DS_Store

# Per-session runtime data created by `wecfu serve` and `wecfu web`.
# This is the user's working directory, never source.
data/

# Optional Segment Anything weights — removed from the project but old
# checkpoints might still be around locally.
*.pth
